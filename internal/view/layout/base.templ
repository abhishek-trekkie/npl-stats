package layout

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta
				name="viewport"
				content="width=device-width, initial-scale=1.0"
			/>
			<title>{ title }</title>
			<link href="/static/css/output.css" rel="stylesheet"/>
		</head>
		<body class="min-h-screen bg-gray-50 text-gray-900">
			@components.Navbar()
			<main>
				{ children... }
			</main>
			@components.Footer()
		</body>
	</html>
}
